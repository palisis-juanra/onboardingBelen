 {{>header}}
    <div class="container d-flex flex-column justify-content-center align-self-center w-50 h-auto p-5 mt-4  bg-light rounded-3 shadow-lg">
        <h2 class="mb-3 text-center">{{tour_name}} Booking</h2>
        {{#available_components.component}}
        <div class="mt-5">
        <form action="http://www.onboardingbelen.local/checkavailability/" name='availabilityForm' method="post">
                <h5 class="form-check-label mt-1" for="{{agecat}}" style="text-indent: 10px">
                    From {{start_date}} to {{end_date}}) : 
                </h5>
        </form>
        </div>
        <button onClick="availabilityForm.submit()" class="w-25 align-self-center p-3 btn btn-primary"  type="submit" >
            <i class="bi bi-heart"></i> Check availability
        </button>
        {{/available_components.component}}
        {{^available_components.component}}
            <h2 class="mb-3 text-center">Sorry we don't have availability for the current date</h2>
        {{/available_components.component}}
    </div>
{{>footer}}