    {{>header}}
            <div class="align-self-center w-100 h-auto p-5 mt-5">
            <form {{#tours.tour}}action="http://www.onboardingbelen.local/tours/{{channel_id}} "{{/tours.tour}} name="channelsForm" method="post">
            <select onChange="channelsForm.submit()" name="selectedChannel" class="form-select" aria-label="Default select example">
            <option selected>Select a channel</option>
               {{#channels.channel}}
                   
                    <option value='{{channel_id}}'>{{channel_name}}</option>
                  
                {{/channels.channel}}
            </select>
            </form>
            <form action="http://www.onboardingbelen.local/tour/" name='tourForm' method="post">
            <div class="justify-content-center d-flex flex-wrap flex-row w-100 mt-5 mb-5">
            {{#tours.tour}}
                    <div class="align-self-center mt-5 card " style="width: 18rem; height: 22rem; margin-left: 1.5%; margin-right:1.5%;">
                        <img class="card-img-top " src='{{thumbnail_image}}' alt="Card image cap">
                        <input type="hidden" value="{{tour_id}}" name="selectedTour" />
                        <input type="hidden" value="{{channel_id}}" name="selectedTourChannel" />
                        <div class="card-body">
                            <h5 class="card-title">{{tour_name}}</h5>
                            <a onClick="tourForm.submit()" class="btn btn-primary p-1">Show tour</a>
                        </div>
                    </div>
            {{/tours.tour}}
            </div>
             </form>
            </div>
    {{>footer}}